NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/reply_assistant

LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_BOT_BASIC_ID=

ADMIN_LINE_USER_IDS=
CONSULTANT_INVITE_CODE=

OFFICIAL_CS_NAME=
OFFICIAL_CS_PHONE=
OFFICIAL_CS_LINE=
OFFICIAL_CS_FORM_URL=
OFFICIAL_CS_URL=
OFFICIAL_CS_SERVICE_HOURS=

LOG_LEVEL=info
USE_MEMORY_REPOS=false
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/reply_assistant_test

# 選填：僅用於顧問私訊 AI 草稿／摘要；未設定不影響系統啟動
OPENAI_API_KEY=

# Vision model（暫不列入使用說明）
OPENAI_VISION_MODEL=gpt-4o

# admin 私訊被動備份提醒天數（預設 7）
KNOWLEDGE_EXPORT_REMINDER_DAYS=7

# 私訊草稿 session 被動過期小時數（預設 24）
DM_SESSION_TIMEOUT_HOURS=24
DEBOUNCE_SECONDS=60

# 群組代回（預設關閉；僅內部保留底層 function，不開放指令入口）
ENABLE_GROUP_PROXY_REPLY=false
