{
  "name": "reply-assistant",
  "version": "1.1.0",
  "description": "客立樂教學小助手 MVP 後端",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node scripts/copy-assets.js",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:init": "npm run db:migrate"
  },
  "dependencies": {
    "@line/bot-sdk": "^9.7.1",
    "express": "^4.21.2",
    "pg": "^8.14.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.1.0",
    "ts-jest": "^29.2.6",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
